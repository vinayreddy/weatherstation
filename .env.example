# Camera
WS_RTSP_STREAM=rtsp://user:pass@192.168.1.x:554/stream
WS_IMAGE_DIR=/path/to/images

# Weather
WS_OPENWEATHER_API_KEY=

# Refresh interval (seconds)
WS_REFRESH_SECS=30

# Alerting via Mailtrap (optional; falls back to log-only alerter)
WS_MAILTRAP_API_TOKEN=
WS_ALERT_EMAIL_TO=
WS_ALERT_EMAIL_FROM=weatherstation@localhost
