# Camera
WS_RTSP_STREAM=rtsp://user:pass@192.168.1.x:554/stream

# Weather Underground (get key at wunderground.com/member/api-keys)
WS_WU_API_KEY=
WS_WU_STATION_ID=KWASEATT3003

# Storage
WS_IMAGE_DIR=./data/images
WS_DB_PATH=./data/weather.db

# Server
WS_HTTP_PORT=8080
WS_REFRESH_SECS=30

# Alerting via Mailtrap (optional; falls back to log-only alerter)
WS_MAILTRAP_API_TOKEN=
WS_ALERT_EMAIL_TO=
WS_ALERT_EMAIL_FROM=weatherstation@localhost
